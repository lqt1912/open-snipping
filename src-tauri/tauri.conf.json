{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "open-snipping",
  "version": "0.1.0",
  "identifier": "com.lqt1912.open-snipping",
  "build": {
    "frontendDist": "../dist/open-snipping/browser",
    "devUrl": "http://localhost:4200",
    "beforeDevCommand": "npm start",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Open Snipping",
        "width": 960,
        "height": 640,
        "minWidth": 640,
        "minHeight": 480,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false,
        "visible": true,
        "skipTaskbar": false,
        "center": true
      },
      {
        "label": "overlay",
        "title": "Open Snipping – Capture",
        "maximized": true,
        "fullscreen": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": false,
        "visible": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$TMPDIR/**", "/tmp/**", "**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}

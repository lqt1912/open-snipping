{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "open-snipping",
  "version": "0.1.0",
  "identifier": "com.lqt1912.open-snipping",
  "build": {
    "frontendDist": "../dist/open-snipping/browser",
    "devUrl": "http://localhost:4200",
    "beforeDevCommand": "npm start",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Open Snipping",
        "width": 360,
        "height": 200,
        "minWidth": 320,
        "minHeight": 160,
        "resizable": false,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false,
        "visible": true,
        "skipTaskbar": false,
        "center": true
      },
      {
        "label": "overlay",
        "title": "Open Snipping – Capture",
        "maximized": true,
        "fullscreen": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$TMPDIR/**", "/tmp/**", "**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "lqt1912",
    "category": "Utility",
    "shortDescription": "A lightweight screenshot and snipping tool for Linux",
    "longDescription": "Open Snipping is a fast, keyboard-friendly screenshot tool for Linux. Select a region of your screen, copy to clipboard, or save as JPEG. Built with Tauri and Angular.",
    "linux": {
      "deb": {
        "depends": ["grim", "scrot", "libwebkit2gtk-4.1-0", "libgtk-3-0"]
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
